# ================================================================
# AutoFleet Pro — Environment Variables
# Copy to .env.local and fill in values
# ================================================================

# ── Supabase (REQUIRED) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
# Backward-compatible fallback if your project still uses the older name:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Anthropic AI (for document extraction) ───────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Sentry (errors / traces / session replay) ────────────────
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
# Optional server-side override; falls back to NEXT_PUBLIC_SENTRY_DSN if omitted
SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
# Optional, only needed for production source map uploads
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# ── Stripe (for subscriptions / SaaS) ────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Resend (for email notifications) ─────────────────────────
# Get from: https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=re_...
